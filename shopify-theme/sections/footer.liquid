<footer class="footer">
  <div class="container footer-grid">
    <div class="footer-col">
      <h3 class="footer-brand">THORN TECH</h3>
      <p class="footer-text">
        The UK's ultimate destination for premium PC components and bespoke enthusiast builds.
      </p>
      <p class="footer-text text-sm" style="margin-top: 1rem; color: #71717a;">
        VAT No: GB 123 4567 89<br/>
        Company Reg: 12345678 (England & Wales)
      </p>
    </div>
    
    <div class="footer-col">
      <h4 class="footer-heading">Shop Categories</h4>
      <ul class="footer-menu">
        <li><a href="/collections/all">Graphics Cards (GPUs)</a></li>
        <li><a href="/collections/all">Processors (CPUs)</a></li>
        <li><a href="/collections/all">Motherboards</a></li>
        <li><a href="/collections/all">Memory & Storage</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h4 class="footer-heading">Customer Service</h4>
      <ul class="footer-menu">
        <li><a href="/pages/contact">Track Order / DPD</a></li>
        <li><a href="/policies/refund-policy">Returns & Refunds</a></li>
        <li><a href="/policies/terms-of-service">UK Warranty Info</a></li>
        <li><a href="/pages/contact">Contact Us</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h4 class="footer-heading">Newsletter</h4>
      <p class="footer-text">Subscribe for hardware drops and exclusive UK deals.</p>
      <form method="post" action="/contact#contact_form" id="contact_form" accept-charset="UTF-8" class="footer-newsletter">
        <input type="hidden" name="form_type" value="customer">
        <input type="hidden" name="utf8" value="✓">
        <input type="email" name="contact[email]" placeholder="Enter your email" required class="newsletter-input">
        <button type="submit" class="btn btn-primary">Subscribe</button>
      </form>
    </div>
  </div>
  
  <div class="container">
    <div class="footer-bottom">
      <p>&copy; {{ 'now' | date: "%Y" }} {{ shop.name }}. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
.footer {
  background-color: #000;
  border-top: 1px solid rgba(255, 255, 255, 0.1);
  padding: 4rem 0 2rem;
  margin-top: 4rem;
}
.footer-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 2rem;
  margin-bottom: 3rem;
}
@media (min-width: 768px) {
  .footer-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}
@media (min-width: 1024px) {
  .footer-grid {
    grid-template-columns: repeat(4, 1fr);
  }
}
.footer-brand {
  font-family: var(--font-heading);
  font-size: 1.25rem;
  font-weight: bold;
  letter-spacing: 0.05em;
  margin-bottom: 1rem;
}
.footer-heading {
  font-family: var(--font-heading);
  font-size: 1.125rem;
  font-weight: bold;
  margin-bottom: 1.25rem;
}
.footer-text {
  color: #a1a1aa;
  font-size: 0.875rem;
  line-height: 1.5;
}
.footer-menu {
  list-style: none;
  padding: 0;
  margin: 0;
}
.footer-menu li {
  margin-bottom: 0.75rem;
}
.footer-menu a {
  color: #a1a1aa;
  font-size: 0.875rem;
  transition: color 0.2s ease;
}
.footer-menu a:hover {
  color: var(--primary);
}
.footer-newsletter {
  display: flex;
  gap: 0.5rem;
  margin-top: 1rem;
}
.newsletter-input {
  flex: 1;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  padding: 0.5rem 1rem;
  color: white;
  border-radius: 4px;
}
.footer-bottom {
  border-top: 1px solid rgba(255, 255, 255, 0.1);
  padding-top: 2rem;
  text-align: center;
  color: #a1a1aa;
  font-size: 0.875rem;
}
</style>

{% schema %}
{
  "name": "Footer",
  "settings": []
}
{% endschema %}